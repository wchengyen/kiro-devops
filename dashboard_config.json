{
  "providers": {
    "aws": {
      "enabled": true,
      "regions": [
        "cn-north-1",
        "cn-northwest-1"
      ]
    },
    "tencent": {
      "enabled": true,
      "regions": [
        "ap-tokyo"
      ]
    }
  },
  "mappings": [
    {
      "name": "rule-1",
      "enabled": true,
      "match": {
        "source": "prometheus",
        "severity": [
          "critical",
          "high"
        ]
      },
      "action": {
        "agent": "eks-alert-analyzer",
        "tools": [
          "execute_bash",
          "fs_read",
          "fs_write",
          "grep",
          "glob"
        ],
        "timeout": 300,
        "instruction": null
      }
    }
  ],
  "service_rules": [
    {
      "field": "title",
      "keyword": "rds",
      "service": "RDS"
    },
    {
      "field": "title",
      "keyword": "ec2",
      "service": "EC2"
    },
    {
      "field": "title",
      "keyword": "cpu",
      "service": "EC2"
    },
    {
      "field": "title",
      "keyword": "memory",
      "service": "EC2"
    },
    {
      "field": "title",
      "keyword": "disk",
      "service": "EC2"
    },
    {
      "field": "title",
      "keyword": "node",
      "service": "EKS"
    },
    {
      "field": "source",
      "keyword": "jenkins",
      "service": "CI/CD"
    },
    {
      "field": "source",
      "keyword": "prometheus",
      "service": "EC2"
    },
    {
      "field": "source",
      "keyword": "cloudwatch",
      "service": "CloudWatch"
    }
  ],
  "pinned_resources": []
}