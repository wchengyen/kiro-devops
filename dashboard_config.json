{
  "providers": {
    "aws": {
      "enabled": true,
      "regions": [
        "cn-north-1",
        "cn-northwest-1"
      ]
    },
    "tencent": {
      "enabled": true,
      "regions": [
        "ap-tokyo"
      ]
    }
  },
  "mappings": [
    {
      "agent": "ec2-alert-analyzer",
      "service": "EC2",
      "severity": "high",
      "skill": "ec2-alert-analyzer",
      "source": "prometheus"
    },
    {
      "agent": "ec2-alert-analyzer",
      "service": "EC2",
      "severity": "critical",
      "skill": "ec2-alert-analyzer",
      "source": "prometheus"
    },
    {
      "source": "prometheus",
      "service": "EKS",
      "severity": "high",
      "agent": "ec2-alert-analyzer",
      "skill": "ec2-alert-analyzer"
    },
    {
      "source": "prometheus",
      "service": "EKS",
      "severity": "critical",
      "agent": "ec2-alert-analyzer",
      "skill": "ec2-alert-analyzer"
    }
  ],
  "service_rules": [
    {
      "field": "title",
      "keyword": "rds",
      "service": "RDS"
    },
    {
      "field": "title",
      "keyword": "ec2",
      "service": "EC2"
    },
    {
      "field": "title",
      "keyword": "cpu",
      "service": "EC2"
    },
    {
      "field": "title",
      "keyword": "memory",
      "service": "EC2"
    },
    {
      "field": "title",
      "keyword": "disk",
      "service": "EC2"
    },
    {
      "field": "title",
      "keyword": "node",
      "service": "EKS"
    },
    {
      "field": "source",
      "keyword": "jenkins",
      "service": "CI/CD"
    },
    {
      "field": "source",
      "keyword": "prometheus",
      "service": "EC2"
    },
    {
      "field": "source",
      "keyword": "cloudwatch",
      "service": "CloudWatch"
    }
  ],
  "pinned_resources": []
}